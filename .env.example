TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Auth mode:
# - per_chat: each Telegram chat has its own isolated Codex login
# - shared: all chats reuse the same mounted Codex config
CODEX_AUTH_MODE=per_chat
CODEX_AUTH_ROOT=/data/auth

# Shared Codex config mount. Used when CODEX_AUTH_MODE=shared.
# You can point this to an existing host profile, or keep the local folder.
CODEX_CONFIG_DIR=./shared-codex

# Mounted host workspace seen by Codex inside the container.
HOST_WORKSPACE=/home/ubuntu
HOST_SHELL_MODE=host

# Official Codex CLI npm channel: latest, alpha, beta, native, or an exact version.
CODEX_CHANNEL=latest
CODEX_MODEL=

# Base flags passed to `codex exec`.
CODEX_EXTRA_ARGS=--skip-git-repo-check --dangerously-bypass-approvals-and-sandbox

# Keep the official Codex CLI up to date through npm before runs.
AUTO_UPDATE=true
AUTO_UPDATE_MIN_INTERVAL_SECONDS=21600

TELEGRAM_PARSE_MODE=HTML
TELEGRAM_POLL_SECONDS=30

# Voice I/O
VOICE_LOCALE=en_US
STT_MODEL=base
# Optional transcription language hint. Leave empty to infer from VOICE_LOCALE.
STT_LANGUAGE=
STT_COMPUTE_TYPE=int8
STT_MODEL_DIR=/data/stt-models
TTS_ENGINE=piper
# Optional explicit Piper voice. Leave empty to auto-pick from VOICE_LOCALE.
TTS_PIPER_VOICE=
TTS_PIPER_DIR=/data/piper-voices
# Optional espeak-ng fallback override. Leave empty to auto-pick from VOICE_LOCALE.
TTS_VOICE=
TTS_SPEED=150
TTS_PITCH=32
TTS_MAX_CHARS=5000
